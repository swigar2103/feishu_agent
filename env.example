BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 编排/规划/JSON 多步调用：务必用「文本对话」模型（如 qwen-plus / qwen-turbo / qwen2.5-7b-instruct）。
# 勿用 qwen2.5-vl-* 等 VL 多模态大模型，否则单次推理极慢，极易触发百炼 RequestTimeOut（约 5 分钟）。
# 示例（按控制台可用名填写，需为文本类）：qwen-plus-2025-07-28
BAILIAN_MODEL_ORCHESTRATOR=qwen-plus-2025-07-28
BAILIAN_MODEL_WRITER=qwen2.5-7b-instruct
BAILIAN_MODEL_EMBEDDING=text-embedding-v3
PORT=3000
HOST=0.0.0.0
# 推荐联调值：60000（避免复杂请求过早超时）
LLM_TIMEOUT_MS=60000
# 当 LLM_TIMEOUT_MS=0 时，单次百炼请求使用此兜底超时（毫秒），避免永久挂起
LLM_ZERO_TIMEOUT_FALLBACK_MS=600000
# 百炼云端超时(500/RequestTimeOut)、限流(429)等时的额外重试次数；默认 2 表示最多共 3 次
LLM_HTTP_RETRIES=2
# 重试间隔基数（毫秒），第 n 次重试前等待约 n * backoff
LLM_RETRY_BACKOFF_MS=4000
# 整条报告 Agent 图的总超时（毫秒）；默认 30 分钟；0 表示不设总上限（不推荐）
REPORT_PIPELINE_TIMEOUT_MS=1800000
# LangGraph 单轮步数上限（默认库内为 25，易被 reviewer 回路触发）；可调大
REPORT_GRAPH_RECURSION_LIMIT=64

# ===== 飞书基础配置（Phase1 + Tool Gateway fallback）=====
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Phase1: 模板复制 + 按节写回所需
FEISHU_TEMPLATE_FILE_TOKEN=
FEISHU_TARGET_FOLDER_TOKEN=
FEISHU_COPY_NAME_PREFIX=AI报告-
FEISHU_IM_NOTIFY_CHAT_ID=

# 飞书 OpenAPI / MCP 的 HTTP 超时（毫秒），默认 90000；设为 0 表示不限时
FEISHU_HTTP_TIMEOUT_MS=90000

# 机器人 webhook IM 链路：full（LangGraph 全链路，默认）| phase1（云文档模板 + 卡片）
FEISHU_BOT_PIPELINE=full
# 双层身份模式：bot_default（推荐，主流程应用身份）| user_default（联调）
FEISHU_IDENTITY_MODE=bot_default
# 用户授权（须与开放平台重定向 URL 一致）。公网示例：
FEISHU_USER_OAUTH_REDIRECT_URI=https://www.feishu.space/api/feishu/auth/callback
# 须与应用后台勾选的用户权限一致（空格分隔）。说明见 README「用户 OAuth Scope 清单」
# MCP search-doc 报 99991679 / search:docs:read 时须包含 search:docs:read，并确保后台为「用户身份」已开通后重新授权
FEISHU_USER_OAUTH_SCOPES=docx:document drive:drive drive:drive.search:readonly search:docs:read contact:user:search contact:user.base:readonly wiki:wiki:readonly
# 新增 scope 后希望强制弹出同意页时设 consent，平时可留空
FEISHU_USER_OAUTH_PROMPT=
FEISHU_USER_OAUTH_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/authorize
# OAuth pending state 文件最多保留多少条（按时间淘汰旧记录）
FEISHU_OAUTH_PENDING_STATE_MAX_ITEMS=200
# 可选：runtime-memories / resource-pool 所在目录（Vercel 未设时默认可写 /tmp/feishu-agent-data）
# FEISHU_WRITABLE_DATA_DIR=
# 可选：与开放平台事件订阅 Verification Token 一致时启用校验
# FEISHU_VERIFICATION_TOKEN=

# ===== Tool Gateway（MCP 优先，失败自动 fallback 到 OpenAPI）=====
# 留空则默认不走 MCP，直接走 fallback adapter
FEISHU_MCP_URL=
# 示例可填：https://mcp.feishu.cn/mcp
# 根据飞书远程 MCP 工具名调整白名单（逗号分隔），须与开放平台文档一致
FEISHU_MCP_ALLOWED_TOOLS=search-doc,fetch-doc,list-docs,fetch-file,create-doc,update-doc,get-comments,add-comments,search-user,get-user
# MCP 身份：tat（默认，租户令牌）| uat（用户令牌，需用户 OAuth + 业务请求带 userId）
FEISHU_MCP_IDENTITY=uat
# create/update 后 fetch-doc 验收：正文最短字符数（0=仅做标题锚点检查）
FEISHU_DOC_PUBLISH_VERIFY_MIN_CHARS=50
# 深读 viewDocument：MCP 返回正文短于该字数时继续尝试 lark-cli / OpenAPI raw_content（0=仅首适配器）
FEISHU_VIEW_DOCUMENT_MIN_CHARS=600

# ===== lark-cli（可选：增强质量；不稳定时可先关闭）=====
LARK_CLI_ENABLED=auto
# 模板层强制 guidance：开启后，若未加载 cli-main docs guidance 会直接报错
LARK_CLI_GUIDANCE_REQUIRED=true
# 若在 PATH 中可省略，否则填绝对路径（Windows 示例：D:\\tools\\lark-cli.exe）
LARK_CLI_BIN=lark-cli
# 可选：使用特定 profile
LARK_CLI_PROFILE=
# bot: 应用身份主流程（推荐部署）；user: 本地联调或用户增强链路
LARK_CLI_DEFAULT_AS=bot
LARK_CLI_TIMEOUT_MS=120000
# docs +create 目标文件夹；留空时回退 FEISHU_TARGET_FOLDER_TOKEN。
# 当 LARK_CLI_DEFAULT_AS=user 且两者都为空时，将自动写入个人知识库（my_library）。
LARK_CLI_FOLDER_TOKEN=
# 命令模板（支持占位符）
LARK_CLI_CMD_DOCS_SEARCH=docs +search
LARK_CLI_CMD_CONTACT_SEARCH=
LARK_CLI_CMD_CONTACT_GET=
LARK_CLI_CMD_SLIDES_CREATE=
# Slides 交付层级：outline_only | artifact_best_effort
FEISHU_SLIDES_DELIVERY_LEVEL=outline_only
# 文档发布策略：gateway_only（推荐稳定）| lark_cli_first（优先 CLI，失败自动回退）
FEISHU_DOC_PUBLISH_STRATEGY=gateway_only
# 文档创建/更新：true 时 lark-cli 失败后不再回退 OpenAPI（仅当你强制 CLI 时用）；MCP 联调建议 false
FEISHU_DOC_LARK_CLI_HARD_PREFER=false

# ===== Resource Screening 阈值 =====
RESOURCE_SCREENING_MIN_CANDIDATE_COUNT=3
RESOURCE_SCREENING_MIN_CANDIDATE_SCORE=0.35

# ----- 真实检索：IM 群聊消息（Phase 4.3）-----
# 想把哪个群的近期讨论作为素材，就填那个群的 chat_id；留空则自动用 FEISHU_NOTIFY_CHAT_ID
# 想完全关掉 IM 检索路：把 FEISHU_SEARCH_CHAT_ID 显式设为 "off"
# FEISHU_SEARCH_CHAT_ID=
# 每次拉最近多少条、打分后返回几条、只看最近多少小时的消息
FEISHU_SEARCH_IM_LIMIT=80
FEISHU_SEARCH_IM_TOP_K=3
FEISHU_SEARCH_IM_WINDOW_HOURS=168

# ----- B：/generate-report 资源池接真飞书（与 Phase1 模板独立）-----
# mock=本地 JSON；real=从云盘文件夹枚举 docx（需 FEISHU_APP_ID/SECRET + 云空间读权限）
FEISHU_RESOURCE_POOL_SOURCE=mock
FEISHU_RESOURCE_FOLDER_TOKEN=
FEISHU_RESOURCE_MAX_DOCX=20
# real 模式下 DFS 子文件夹的最大深度（含根下列举），避免极深目录拖慢或爆栈风险
FEISHU_RESOURCE_MAX_FOLDER_DEPTH=16
