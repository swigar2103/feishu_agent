BAILIAN_API_KEY=
BAILIAN_BASE_URL
BAILIAN_MODEL_ORCHESTRATOR=
BAILIAN_MODEL_WRITER=
BAILIAN_MODEL_EMBEDDING=
PORT=3000
HOST=0.0.0.0
LLM_TIMEOUT_MS=0

# ===== 飞书（Phase 4）=====
# 填了 AppID + AppSecret 后就会自动启用真实飞书模式
# 没填的话默认走 mock，主流程不受影响
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 手动控制：auto / true / false
#   auto  = 有凭证走 real，没凭证走 mock（默认）
#   true  = 强制 mock
#   false = 强制 real（凭证缺失会自动降级回 mock 并打警告）
FEISHU_USE_MOCK=auto

FEISHU_DOMAIN=open.feishu.cn

# ----- 报告通知（Phase 4.6）-----
# 生成完报告后，自动把摘要卡片发到飞书。三选一，优先级 chat_id > open_id > email：
FEISHU_NOTIFY_CHAT_ID=
# FEISHU_NOTIFY_OPEN_ID=                         # 想切到私聊你自己就解开这行并把上面那行注释掉
# FEISHU_NOTIFY_EMAIL=you@company.com
FEISHU_NOTIFY_ENABLED=true

# ----- 云文档回写（Phase 5）-----
# auto：有权限自动写；true：强制写；false：关闭
FEISHU_DOCX_ENABLED=auto
# 可选：指定把创建的周报云文档落在哪个文件夹下，留空 = 我的空间根目录
# 拿法：浏览器打开目标文件夹，URL 里 /drive/folder/<TOKEN> 那段就是
# FEISHU_DOCX_FOLDER_TOKEN=
# 卡片里 "查看完整文档" 按钮的跳转前缀；默认 www.feishu.cn 会自动跳到你租户
# 如果你有自定义租户域名（yourco.feishu.cn）换成那个体验更好
# FEISHU_DOCX_URL_PREFIX=https://www.feishu.cn/docx/

# ----- 真实检索（Phase 4.2）-----
# 飞书云盘里一个文件夹的 token，里面放你的素材 docx（周报模板、历史报告、业务资料）
# 拿法：飞书云盘打开那个文件夹，URL 里 /drive/folder/<TOKEN> 那段
# 留空的话 Retrieval 层仍走 mock（不阻塞主流程）
FEISHU_SEARCH_FOLDER_TOKEN=
# 单次最多扫几个 docx（避免大文件夹拖慢）；单次最多返回给主流程几条素材
FEISHU_SEARCH_MAX_DOCS=10
FEISHU_SEARCH_TOP_K=5

# ----- 真实检索：IM 群聊消息（Phase 4.3）-----
# 想把哪个群的近期讨论作为素材，就填那个群的 chat_id；留空则自动用 FEISHU_NOTIFY_CHAT_ID
# 想完全关掉 IM 检索路：把 FEISHU_SEARCH_CHAT_ID 显式设为 "off"
# FEISHU_SEARCH_CHAT_ID=
# 每次拉最近多少条、打分后返回几条、只看最近多少小时的消息
FEISHU_SEARCH_IM_LIMIT=80
FEISHU_SEARCH_IM_TOP_K=3
FEISHU_SEARCH_IM_WINDOW_HOURS=168